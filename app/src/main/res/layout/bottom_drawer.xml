<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorSurface"
    android:elevation="16dp"
    android:orientation="vertical"
    app:behavior_hideable="false"
    app:behavior_peekHeight="48dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!--
        Peek area: ViewFlipper 48dp
        Index 0 = header_status  (default, saat collapsed & keyboard tidak aktif)
        Index 1 = symbol_view    (saat keyboard virtual aktif & collapsed)
    -->
    <ViewFlipper
        android:id="@+id/header_flipper"
        android:layout_width="match_parent"
        android:layout_height="48dp">

        <!-- Index 0: Status Build -->
        <LinearLayout
            android:id="@+id/header_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?colorSurface"
            android:foreground="?attr/selectableItemBackground">

            <TextView
                android:id="@+id/tv_build_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Build Ready"
                android:textColor="?colorTertiary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:typeface="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap or swipe up to see the build log"
                android:textSize="9sp"
                android:typeface="monospace" />

        </LinearLayout>

        <!-- Index 1: Symbol View (proxy — akan diisi dari editor_fragment via kode) -->
        <HorizontalScrollView
            android:id="@+id/symbol_view_container_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?colorSurfaceContainerLow"
            android:scrollbars="none">

            <io.github.rosemoe.sora.widget.SymbolInputView
                android:id="@+id/symbol_view_sheet"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:backgroundTint="?colorSurfaceContainerLow" />

        </HorizontalScrollView>

    </ViewFlipper>

    <!-- Expanded content: divider + toolbar + tab + pager -->
    <LinearLayout
        android:id="@+id/expanded_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/dividerVertical" />

        <!-- Toolbar: judul + tombol aksi -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:paddingHorizontal="12dp"
            android:background="?colorSurface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Console &amp; Logs"
                android:textStyle="bold"
                android:textSize="13sp"
                android:typeface="monospace" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_reload_output"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/round_refresh_24"
                    app:tint="?colorPrimary"
                    android:contentDescription="Reload" />

                <ImageButton
                    android:id="@+id/btn_stop_output"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/baseline_close_24"
                    app:tint="?colorError"
                    android:contentDescription="Stop"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/btn_clear_log"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_delete_sweep"
                    app:tint="?colorOnSurfaceVariant"
                    android:contentDescription="Clear" />

            </LinearLayout>
        </RelativeLayout>

        <!-- TabLayout -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/bottom_drawer_tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabIconTint="?colorPrimary"
            app:tabIndicatorFullWidth="true"
            app:tabInlineLabel="true"
            app:tabMode="fixed"
            app:tabSelectedTextColor="?colorPrimary"
            app:tabTextColor="?colorOnSurfaceVariant" />

        <!-- Pager mengisi sisa ruang -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/bottom_drawer_pager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="?colorSurface" />

    </LinearLayout>

</LinearLayout>