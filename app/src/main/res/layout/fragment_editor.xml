<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorSurfaceContainerLow">

    <!--
        RelativeLayout sebagai root konten (mengikuti pola AndroidIDE):
        - AppBar di atas
        - bottom_sheet fixed di bawah (layout_alignParentBottom)
        - editor_container mengisi sisa ruang di antara keduanya
        Tidak ada CoordinatorLayout / BottomSheetBehavior.
        Tinggi bottom_sheet dikontrol via kode (expand/collapse).
    -->
    <RelativeLayout
        android:clipChildren="true"
        android:clipToPadding="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- AppBar: Toolbar + Tab file -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="?colorSurfaceContainerLow">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:menu="@menu/menu_main"
                app:navigationIcon="@drawable/ic_menu" />

            <!-- Material 3 Linear Progress Indicator -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/compile_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                android:visibility="gone"
                app:trackThickness="3dp" />

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?colorSurfaceContainerLow"
                app:tabGravity="start"
                app:tabInlineLabel="true"
                app:tabMode="scrollable" />

        </com.google.android.material.appbar.AppBarLayout>

        <include
            android:id="@+id/search_layout"
            layout="@layout/layout_search_replace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/app_bar"
            android:visibility="gone" />

        <!--
            Bottom drawer: fixed di bawah, tinggi awal = peekHeight (60dp).
            Saat di-expand, tinggi diperbesar dari kode.
            layout_alignParentBottom memastikan selalu menempel di bawah area visible.
        -->
        <include
            layout="@layout/bottom_drawer"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true" />

        <!-- Editor pager: mengisi ruang antara AppBar dan bottom_sheet -->
        <ViewFlipper
            android:id="@+id/view_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/search_layout"
            android:layout_above="@id/bottom_sheet">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/no_editor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/no_open_files"
                    android:textAppearance="?attr/textAppearanceTitleLarge" />

                <TextView
                    android:id="@+id/no_editor_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginHorizontal="8dp"
                    android:gravity="center"
                    android:text="@string/no_open_files_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textAlignment="center"
                    android:textColor="?android:attr/textColorSecondary" />

            </LinearLayout>

        </ViewFlipper>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="start">

        <include
            android:id="@+id/included"
            layout="@layout/drawer_content" />

    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>