{
  "name": "Build",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#log_patterns"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "token.warn-token",
          "match": "WARNING:|warn:|WARN:|Warning:"
        },
        {
          "name": "token.info-token",
          "match": "INFO:|info:|Info:"
        },
        {
          "name": "token.error-token",
          "match": "ERROR:|error:|Error:"
        },
        {
          "name": "token.debug-token",
          "match": "OUTPUT:"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.build",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.build",
          "match": "\\\\."
        }
      ]
    },
    "log_patterns": {
      "patterns": [

        {
          "comment": "RKB reporter special token",
          "match": "\\b(RKB-reporter)\\b",
          "name": "log.text strong"
        },

        {
          "comment": "Full WARNING log line",
          "match": "^\\[WARNING\\]\\s*([\\d\\-\\:\\.\\s]+).*\\[W\\]\\s(.*)",
          "name": "log.warning"
        },
        {
          "comment": "Full ERROR log line",
          "match": "^\\[ERROR\\]\\s*([\\d\\-\\:\\.\\s]+).*\\[E\\]\\s(.*)",
          "name": "log.error"
        },

        {
          "comment": "FAILURE / FAILED lines",
          "match": "^.*(FAILURE|FAILED).*$",
          "name": "log.error2 strong"
        },

        {
          "comment": "BUILD SUCCESSFUL with timing: green bold",
          "match": "^BUILD\\sSUCCESSFUL(\\sin\\s\\d+[smh]+)?.*$",
          "name": "success strong"
        },

        {
          "comment": "What went wrong",
          "match": "^\\*\\sWhat\\swent\\swrong\\:$",
          "name": "log.error2 strong"
        },
        {
          "comment": "Try suggestion",
          "match": "^\\*\\sTry\\:$",
          "name": "log.warning strong"
        },

        {
          "comment": "Separator line of dashes",
          "match": "^[-]{3,}$",
          "name": "log.text2 strong"
        },

        {
          "comment": "Separator line with pipes: | TITLE |",
          "match": "^\\|.*\\|$",
          "name": "log.info strong"
        },

        {
          "comment": "Label: Value lines e.g. Awal Bulan: Ramadan, Tahun: 1434",
          "match": "^([A-Za-z][\\w\\s]*?):\\s+(.+)$",
          "captures": {
            "1": { "name": "log.text strong" },
            "2": { "name": "log.string" }
          },
          "name": "log.text"
        },

        {
          "comment": "Gradle > Task lines with status NO-SOURCE UP-TO-DATE SKIPPED",
          "match": "(NO-SOURCE|UP-TO-DATE|SKIPPED|FROM-CACHE)",
          "name": "log.debug strong"
        },

        {
          "comment": "Gradle task lines: > Task :app:something",
          "match": "^>\\sTask\\s(:[\\w:\\-]+).*$",
          "captures": {
            "1": { "name": "log.info" }
          },
          "name": "log.info"
        },

        {
          "comment": "Run tasks line",
          "match": "^Run\\stasks\\s:\\s\\[.*\\]$",
          "name": "log.info strong"
        },

        {
          "comment": "Configure project line",
          "match": "^>\\sConfigure\\sproject\\s.*$",
          "name": "log.info"
        },

        {
          "comment": "Actionable tasks summary e.g. 4 actionable tasks: 3 executed, 1 up-to-date",
          "match": "^\\d+\\sactionable\\stask.*$",
          "name": "log.debug"
        },

        {
          "comment": "See the profiling / fine-grained lines",
          "match": "^(See the profiling report at:|A fine-grained performance profile is available.*)$",
          "name": "log.debug"
        },

        {
          "comment": "[Incubating] or [something] bracketed prefix - whole line",
          "match": "^(\\[\\w+\\])\\s(.*)$",
          "captures": {
            "1": { "name": "log.warning strong" },
            "2": { "name": "log.text" }
          },
          "name": "log.text"
        },

        {
          "comment": "file:/// or file:// paths",
          "match": "file:\\/\\/\\/[^\\s,\"]+",
          "name": "link strong"
        },

        {
          "comment": "http/https URLs",
          "match": "https?:\\/\\/(?:www\\.)?[-a-zA-Z0-9@:%._\\+~#=]{1,256}\\.[a-zA-Z0-9()]{1,6}\\b(?:[-a-zA-Z0-9()@:%_\\+.~#?&//=]*)",
          "name": "link strong"
        },
        {
          "comment": "Other protocol URLs",
          "match": "\\b[a-z]+://\\S+\\b/?",
          "name": "link strong"
        },

        {
          "comment": "Version tag like v1.0",
          "match": "\\bv\\d+\\.\\d+\\b",
          "name": "log.text strong"
        },

        {
          "comment": "Dotted class names like org.gradle.api.plugins.Convention",
          "match": "\\b([a-z][a-z0-9]*\\.){2,}[A-Za-z][A-Za-z0-9]*\\b",
          "name": "log.string"
        },

        {
          "comment": "Single dot property/file like sdk.dir local.properties",
          "match": "\\b[a-zA-Z][a-zA-Z0-9_]*\\.[a-zA-Z][a-zA-Z0-9_]*\\b",
          "name": "log.string"
        },

        {
          "comment": "Scientific notation like 5.0E-4",
          "match": "-?\\b\\d+\\.\\d+E[+-]?\\d+\\b",
          "name": "log.string"
        },

        {
          "comment": "Decimal / floating point numbers",
          "match": "-?\\b\\d+\\.\\d+\\b",
          "name": "log.string"
        },

        {
          "comment": "HMS timestamp like 0:5:12.54",
          "match": "\\b\\d+:\\d+:\\d+\\.\\d+\\b",
          "name": "log.string"
        },

        {
          "comment": "Standard log timestamp HH:MM:SS.mmm",
          "match": "(\\d{2}-\\d{2}\\s)?\\d{2}:\\d{2}:\\d{2}\\.\\d{3}(\\s*\\d+)?(\\s*\\d+)?",
          "name": "log.string"
        },

        {
          "comment": "Single-quoted strings",
          "match": "(?<![\\w])'[^']*'",
          "name": "log.string"
        },
        {
          "comment": "Backtick strings",
          "match": "(?<![\\w])`[^`]*`",
          "name": "log.string"
        },

        {
          "comment": "Git hashes",
          "match": "\\b([0-9a-fA-F]{40}|[0-9a-fA-F]{10}|[0-9a-fA-F]{7})\\b",
          "name": "log.text"
        },
        {
          "comment": "UUIDs",
          "match": "\\b[0-9a-fA-F]{8}[-]?([0-9a-fA-F]{4}[-]?){3}[0-9a-fA-F]{12}\\b",
          "name": "log.text"
        },
        {
          "comment": "MAC addresses",
          "match": "\\b([0-9a-fA-F]{2,}[:-])+[0-9a-fA-F]{2,}+\\b",
          "name": "log.text"
        },

        {
          "comment": "Integer numbers",
          "match": "\\b([0-9]+)\\b",
          "name": "log.number strong"
        },

        {
          "match": "\\b(true|false|null)\\b",
          "name": "log.error2 strong"
        },
        {
          "match": "\\b(0x[a-fA-F0-9]+)\\b",
          "name": "log.text strong"
        },
        {
          "match": "\\b([a-zA-Z.]*Exception)\\b",
          "name": "log.error strong"
        },

        {
          "begin": "^[(?:\\t| {4}|\\•{4}) ]*at[(?:\\t| {4}|\\•{4}) ]",
          "end": "$",
          "name": "log.error"
        },
        {
          "match": "^(?:(?:\\t| {4}|\\•{4}).*(?:\\r?\\n|$))+",
          "name": "log.text2"
        },

        {
          "comment": "Log level keywords",
          "match": "\\b(DEBUG|NOTE\\:|D)\\b",
          "name": "log.debug strong"
        },
        {
          "match": "\\b(INFO|I)\\b",
          "name": "log.info strong"
        },
        {
          "match": "\\b(WARNING|WARN|warn\\:|W)\\b",
          "name": "log.warning strong"
        },
        {
          "match": "\\b(ERROR|error\\:|ERR|err\\:|E)\\b",
          "name": "log.error2 strong"
        },

        {
          "comment": "domain-like text",
          "match": "(?<![\\w/\\\\])([\\w-]+\\.)+([\\w-])+(?![\\w/\\\\])",
          "name": "log.text"
        }
      ]
    }
  },
  "scopeName": "source.build"
}